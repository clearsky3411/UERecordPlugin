{
	"schema_version": 1,
	"meta": {
		"registry_name": "VdjmMobileUi",
		"display_name": "VdjmMobileUi Asset Registry",
		"owner": "vdjm",
		"description": "Central asset registry for confirmed VdjmMobileUi plugin assets.",
		"schema_note": "v1 keeps asset management separate from runtime access enforcement."
	},
	"defines": {
		"TYPE_IMAGE": "image",
		"TYPE_SVG": "svg",
		"TYPE_WIDGET_BP": "widget_bp",
		"TYPE_BLUEPRINT": "blueprint",
		"TYPE_DATA_ASSET": "data_asset",
		"TYPE_ANIMATION": "animation",
		"TYPE_SOUND": "sound",
		"TYPE_MATERIAL": "material",
		"TYPE_FONT": "font",
		"TYPE_MAP": "map",
		"TYPE_LEVEL_SEQUENCE": "level_sequence",
		"TYPE_MEDIA": "media",
		"TYPE_SHADER": "shader",
		"TYPE_RAW_FILE": "raw_file",
		"TYPE_OTHER": "other",
		"CLASS_TEXTURE2D": "/Script/Engine.Texture2D",
		"CLASS_USER_WIDGET": "/Script/UMG.UserWidget",
		"CLASS_BLUEPRINT": "/Script/Engine.Blueprint",
		"CLASS_DATA_ASSET": "/Script/Engine.DataAsset",
		"CLASS_SOUND_BASE": "/Script/Engine.SoundBase",
		"CLASS_MATERIAL_INTERFACE": "/Script/Engine.MaterialInterface",
		"CLASS_WORLD": "/Script/Engine.World",
		"CLASS_VCARD_DESCRIPTOR_REGISTRY": "/Script/VdjmVcard.VcardDescriptorRegistryDataAsset",
		"DIR_UI": "UI",
		"DIR_PREVIEW": "UI/Preview",
		"DIR_ICONS": "UI/Icons"
	},
	"paths": {
		"roots": {
			"plugin": {
				"default_path": ".",
				"scan": false,
				"meta": {
					"purpose": "Plugin root. Usually not scanned because it includes source and tool files."
				}
			},
			"content": {
				"default_path": "Content",
				"scan": true,
				"meta": {
					"purpose": "Plugin content root."
				}
			},
			"config": {
				"default_path": "Config",
				"scan": false,
				"meta": {
					"purpose": "Plugin config root."
				}
			},
			"resources": {
				"default_path": "Resources",
				"scan": true,
				"meta": {
					"purpose": "Plugin resource files."
				}
			},
			"shaders": {
				"default_path": "Shaders",
				"scan": true,
				"meta": {
					"purpose": "Plugin shader files."
				}
			}
		},
		"external_paths": {},
		"defined_roots": [
			{
				"key": "preview-ui",
				"root": "content",
				"relative_path": "!{DIR_PREVIEW}",
				"scan": false,
				"meta": {
					"purpose": "Preview UI folder shortcut."
				}
			},
			{
				"key": "icons",
				"root": "content",
				"relative_path": "!{DIR_ICONS}",
				"scan": false,
				"meta": {
					"purpose": "Icon folder shortcut."
				}
			}
		]
	},
	"virtuals": {
		"key": "root",
		"label": "Root",
		"meta": {
			"purpose": "Virtual folder root. It is not a physical path."
		},
		"children": [
			{
				"key": "recorder",
				"label": "Recorder",
				"meta": {
					"purpose": "Recorder feature assets."
				},
				"children": [
					{
						"key": "loading",
						"label": "Loading",
						"meta": {
							"purpose": "Recorder loading assets."
						},
						"children": [
							{
								"key": "preview",
								"label": "Preview Loading",
								"meta": {
									"purpose": "Preview loading screen assets."
								},
								"children": []
							}
						]
					},
					{
						"key": "preview",
						"label": "Preview",
						"meta": {
							"purpose": "Preview gallery and carousel assets."
						},
						"children": [
							{
								"key": "carousel",
								"label": "Carousel",
								"meta": {
									"purpose": "Carousel card, media, and control assets."
								},
								"children": []
							}
						]
					}
				]
			},
			{
				"key": "vcard",
				"label": "VCard",
				"meta": {
					"purpose": "VCard-facing assets."
				},
				"children": [
					{
						"key": "icons",
						"label": "Icons",
						"meta": {
							"purpose": "VCard icon assets."
						},
						"children": []
					},
					{
						"key": "descriptors",
						"label": "Descriptors",
						"meta": {
							"purpose": "VCard descriptor registry and composition data assets."
						},
						"children": []
					},
					{
						"key": "background",
						"label": "Background",
						"meta": {
							"purpose": "VCard background preset and runtime upload assets."
						},
						"children": []
					},
					{
						"key": "motion",
						"label": "Motion",
						"meta": {
							"purpose": "VCard motion preset, upload, and analysis assets."
						},
						"children": []
					}
				]
			}
		]
	},
	"asset_types": {
		"image": {
			"kind": "unreal_asset",
			"default_class": "!{CLASS_TEXTURE2D}",
			"extensions": [
				".png",
				".jpg",
				".jpeg",
				".tga",
				".bmp",
				".webp"
			],
			"meta": {
				"purpose": "Texture or image asset."
			}
		},
		"svg": {
			"kind": "file",
			"default_class": "",
			"extensions": [
				".svg"
			],
			"meta": {
				"purpose": "SVG source file."
			}
		},
		"widget_bp": {
			"kind": "unreal_asset",
			"default_class": "!{CLASS_USER_WIDGET}",
			"extensions": [
				".uasset"
			],
			"meta": {
				"purpose": "UserWidget blueprint asset."
			}
		},
		"blueprint": {
			"kind": "unreal_asset",
			"default_class": "!{CLASS_BLUEPRINT}",
			"extensions": [
				".uasset"
			],
			"meta": {
				"purpose": "General blueprint asset."
			}
		},
		"data_asset": {
			"kind": "unreal_asset",
			"default_class": "!{CLASS_DATA_ASSET}",
			"extensions": [
				".uasset"
			],
			"meta": {
				"purpose": "DataAsset or data-only UObject asset."
			}
		},
		"vcard_descriptor_registry": {
			"kind": "unreal_asset",
			"default_class": "!{CLASS_VCARD_DESCRIPTOR_REGISTRY}",
			"extensions": [
				".uasset"
			],
			"meta": {
				"purpose": "VCard descriptor registry DataAsset."
			}
		},
		"animation": {
			"kind": "unreal_asset",
			"default_class": "",
			"extensions": [
				".uasset"
			],
			"meta": {
				"purpose": "Animation asset."
			}
		},
		"sound": {
			"kind": "unreal_asset",
			"default_class": "!{CLASS_SOUND_BASE}",
			"extensions": [
				".wav",
				".mp3",
				".ogg",
				".flac"
			],
			"meta": {
				"purpose": "Sound or audio asset."
			}
		},
		"material": {
			"kind": "unreal_asset",
			"default_class": "!{CLASS_MATERIAL_INTERFACE}",
			"extensions": [
				".uasset"
			],
			"meta": {
				"purpose": "Material asset."
			}
		},
		"font": {
			"kind": "unreal_asset",
			"default_class": "",
			"extensions": [
				".ttf",
				".otf",
				".uasset"
			],
			"meta": {
				"purpose": "Font asset or font file."
			}
		},
		"map": {
			"kind": "unreal_asset",
			"default_class": "!{CLASS_WORLD}",
			"extensions": [
				".umap"
			],
			"meta": {
				"purpose": "Map or world asset."
			}
		},
		"level_sequence": {
			"kind": "unreal_asset",
			"default_class": "",
			"extensions": [
				".uasset"
			],
			"meta": {
				"purpose": "Level sequence asset."
			}
		},
		"media": {
			"kind": "file",
			"default_class": "",
			"extensions": [
				".mp4",
				".mov",
				".webm"
			],
			"meta": {
				"purpose": "Media file or media asset."
			}
		},
		"shader": {
			"kind": "file",
			"default_class": "",
			"extensions": [
				".usf",
				".ush",
				".hlsl"
			],
			"meta": {
				"purpose": "Shader source file."
			}
		},
		"raw_file": {
			"kind": "file",
			"default_class": "",
			"extensions": [],
			"meta": {
				"purpose": "Plain file managed by the registry."
			}
		},
		"other": {
			"kind": "unknown",
			"default_class": "",
			"extensions": [],
			"meta": {
				"purpose": "Fallback type for assets that need manual classification."
			}
		}
	},
	"assets": [
		{
			"asset_key": "data_asset:content:Record/Bp_VdjmRecordConfigDataAsset",
			"type": "!{TYPE_DATA_ASSET}",
			"root": "content",
			"relative_path": "Record/Bp_VdjmRecordConfigDataAsset",
			"importance": "optional",
			"class": "!{CLASS_DATA_ASSET}",
			"tags": [
				"record",
				"config"
			],
			"meta": {
				"purpose": "Initial scanned plugin asset. Class can be refined after editor registry inspection."
			}
		},
		{
